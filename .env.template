# YoAgent — Environment Variables Template
# Copy this file to .env and fill in your credentials.
# Never commit .env to Git.

# ── Instagram Scraping ────────────────────────────────────────
# Required for scraping Reels from public profiles.
# Run `python scripts/get_youtube_token.py` first to set up YouTube.

IG_SCRAPE_USER=your_instagram_username
IG_SESSION_ID=your_instagram_session_id
# How to get IG_SESSION_ID:
#   1. Log into Instagram in your browser
#   2. Open DevTools → Application → Cookies → instagram.com
#   3. Copy the value of the "sessionid" cookie

# ── YouTube OAuth2 ────────────────────────────────────────────
# Required for uploading Shorts to YouTube.
# Get these from Google Cloud Console (APIs & Services → Credentials).
# Then run: python scripts/get_youtube_token.py
# to complete the OAuth2 flow and get your YOUTUBE_REFRESH_TOKEN.

YOUTUBE_CLIENT_ID=your_google_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_google_oauth_client_secret
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token

# ── Local Dev: YouTube Cookie Auth (yt-dlp) ───────────────────
# GitHub Actions runners are flagged as bots by YouTube — passing cookies
# bypasses this. For local testing, point this at your filtered cookie file.
# Run: python scripts/filter_yt_cookies.py cookies.txt
# This produces yt_cookies_slim.txt which is used below.
# In CI this is handled automatically via the YOUTUBE_COOKIES_B64 secret.
YOUTUBE_COOKIES_FILE=yt_cookies_slim.txt
