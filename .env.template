# ============================================================
# InstaAgent — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Meta / Instagram ─────────────────────────────────────────
# Long-lived access token from Meta Developer Console
META_ACCESS_TOKEN=your_meta_long_lived_access_token_here

# Your Instagram Business/Creator Account ID (numeric)
IG_ACCOUNT_ID=your_instagram_account_id_here

# ── Cloudinary ───────────────────────────────────────────────
# Get these from your Cloudinary Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Facebook Page ─────────────────────────────────────────────
# Long-lived Page Access Token from developers.facebook.com/tools/explorer
# Permissions needed: pages_manage_posts, pages_read_engagement
FB_PAGE_ACCESS_TOKEN=
FB_PAGE_ID=

# ── Repost Scraping ──────────────────────────────────────────
# A secondary/burner IG account for read-only scraping.
# RECOMMENDED: Use IG_SESSION_ID (browser cookie) to bypass IP blacklisting.
IG_SESSION_ID=

# Fallback: username + password (may be blocked on new IPs)
IG_SCRAPE_USER=
IG_SCRAPE_PASS=
